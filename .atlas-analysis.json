  "keyFeatures": [
    "Game server management with Pterodactyl Wings compatibility",
    "Real-time server console with xterm.js",
    "File management with Monaco editor",
    "Automated backups and schedules",
    "User authentication with 2FA and API keys",
    "Admin dashboard for nodes, locations, and resources",
    "Database management and SSH key support",
    "CLI tool for deployment and PM2 process management"
  ],
  "publicApiSurface": [
    "POST /api/auth/sign-in",
    "GET /api/account/profile",
    "POST /api/account/api-keys",
    "GET /api/client/servers",
    "POST /api/client/servers/:id/power",
